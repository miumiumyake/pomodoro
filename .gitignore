.pio
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch
# В PowerShell:
New-Item -Path .gitignore -Value @"
# PlatformIO
.pio/
.pio-build/
.pioenvs/
.piolibdeps/

# Compiled files
*.bin
*.elf
*.o
*.a
*.hex

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.log
*.cache

# Dependencies (управляются через platformio.ini)
lib/
libdeps/
"@